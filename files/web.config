<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <!--
    ============================================================
    GOA Login Forensics Dashboard — web.config
    ============================================================
    EDIT REQUIRED:
      1. Replace YOUR_SQL_SERVER with your SQL Server FQDN/instance
         e.g. SRVDB01.domain.local  or  SRVDB01\INSTANCE
      2. The App Pool identity (service account) must have at minimum:
         db_datareader on REMEDY_Info database
    ============================================================
  -->

  <connectionStrings>
    <add name="GOALogins"
         connectionString="Server=YOUR_SQL_SERVER;Database=REMEDY_Info;Integrated Security=True;TrustServerCertificate=True;Connect Timeout=60;Application Name=GOAForensicsDashboard;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <appSettings>
    <!-- Auto-refresh interval for live feed (seconds) -->
    <add key="AutoRefreshSeconds" value="60" />
    <!-- Default look-back for Overview charts (days) -->
    <add key="DefaultDaysBack" value="30" />
  </appSettings>

  <system.web>
    <compilation debug="false" targetFramework="4.8">
      <assemblies>
        <add assembly="System.Web.Extensions, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31BF3856AD364E35" />
      </assemblies>
    </compilation>
    <httpRuntime targetFramework="4.8"
                 maxRequestLength="32768"
                 executionTimeout="120"
                 enableVersionHeader="false" />

    <!-- Anonymous access — all domain users can view the dashboard.
         The service account (App Pool identity) authenticates to SQL Server. -->
    <authentication mode="None" />
    <authorization>
      <allow users="*" />
    </authorization>

    <customErrors mode="Off" />

    <httpHandlers>
      <add verb="GET,POST" path="api/api.ashx" type="System.Web.UI.SimpleHandlerFactory" />
    </httpHandlers>
  </system.web>

  <system.webServer>
    <!-- Remove the X-Powered-By header -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
      </customHeaders>
    </httpProtocol>

    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- Serve the ASHX handler -->
    <handlers>
      <add name="GOAApiHandler"
           path="api/api.ashx"
           verb="GET,POST"
           type="System.Web.UI.SimpleHandlerFactory"
           resourceType="Unspecified"
           preCondition="integratedMode" />
    </handlers>

    <modules runAllManagedModulesForAllRequests="true" />

    <httpErrors errorMode="DetailedLocalOnly" existingResponse="PassThrough" />

    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="33554432" />
      </requestFiltering>
    </security>
  </system.webServer>

</configuration>
